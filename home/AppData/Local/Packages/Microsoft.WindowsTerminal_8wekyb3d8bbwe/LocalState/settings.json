    "schemes": [
        {
            "name": "Tokyo Night",
            "background": "#1a1b26",
            "foreground": "#c0caf5",
            "cursorColor": "#c0caf5",
            "selectionBackground": "#283457",
            "black": "#15161e",
            "brightBlack": "#414868",
            "red": "#f7768e",
            "brightRed": "#f7768e",
            "green": "#9ece6a",
            "brightGreen": "#9ece6a",
            "yellow": "#e0af68",
            "brightYellow": "#e0af68",
            "blue": "#7aa2f7",
            "brightBlue": "#7aa2f7",
            "purple": "#bb9af7",
            "brightPurple": "#bb9af7",
            "cyan": "#7dcfff",
            "brightCyan": "#7dcfff",
            "white": "#a9b1d6",
            "brightWhite": "#c0caf5"
        }
    ],

    "actions": [
        { "command": "paste", "keys": "ctrl+v" },
        { "command": { "action": "copy", "singleLine": false }, "keys": "ctrl+c" },
        { "command": { "action": "splitPane", "split": "auto" }, "keys": "alt+shift+d" },
        { "command": "find", "keys": "ctrl+shift+f" },
        { "command": { "action": "newTab" }, "keys": "ctrl+shift+t" },
        { "command": "closePane", "keys": "ctrl+shift+w" }
    ]
