# Git 設定檔
# vim: ft=gitconfig

# --- 使用者設定 ---
[user]
	name = Far Tseng
	email = {{ .email | quote }}
	signingkey = ~/.ssh/id_ed25519.pub

# --- 核心設定 ---
[core]
	quotepath = false
	excludesfile = ~/.gitignore
	pager = delta
	fsmonitor = true
	untrackedcache = true

# --- 初始化設定 ---
[init]
	defaultBranch = main

# --- SSH 簽署設定 ---
[gpg]
	format = ssh

[commit]
	gpgsign = true

[tag]
	gpgsign = true

# --- 分支操作設定 ---
[pull]
	rebase = true

[push]
	autoSetupRemote = true
	default = current

[rebase]
	autoStash = true
	updateRefs = true

[branch]
	sort = -committerdate

# --- 合併與差異比較 ---
[merge]
	log = true
	conflictstyle = zdiff3

[diff]
	algorithm = histogram
	mnemonicPrefix = true
	colorMoved = default
	submodule = log

[interactive]
	diffFilter = delta --color-only

# --- Delta 美化設定 ---
[delta]
	syntax-theme = tokyonight_night
	navigate = true
	tabs = 2
	side-by-side = true
	line-numbers = true
	file-decoration-style = blue ol
	hunk-header-decoration-style = blue box
	commit-decoration-style = bold yellow box ul

# --- 狀態與日誌 ---
[status]
	submodulesummary = true

[log]
	decorate = short
	abbrevcommit = true
	date = relative

[format]
	pretty = "%C(yellow)%h %C(magenta)%<(15,trunc)%an %C(cyan)%cd %C(auto)%d%Creset %s"

# --- 遠端與快取 ---
[fetch]
	prune = true
	pruneTags = true
	writeCommitGraph = true

[transfer]
	fsckObjects = true

[receive]
	fsckObjects = true

[rerere]
	enabled = true

# --- 輔助 ---
[column]
	ui = auto

[help]
	autocorrect = prompt

# --- ghq ---
[ghq]
	root = ~/codebase

# --- LFS ---
[filter "lfs"]
	process = git-lfs filter-process
	required = true
	clean = git-lfs clean -- %f
	smudge = git-lfs smudge -- %f

# --- 別名 ---
[alias]
	st = status
	br = branch
	ci = commit -v
	co = checkout
	sw = switch
	re = restore
	d = diff --color-words=.
	lol = log --graph --all
	lo = log --graph
	last = log -1 HEAD
	f = "!if [[ $(git rev-parse --abbrev-ref HEAD) == 'main' ]]; then git fetch --no-tags origin main; else git fetch --no-tags origin $(git rev-parse --abbrev-ref HEAD) main:main; fi"
	p = "!git pull --no-tags origin $(git rev-parse --abbrev-ref HEAD)"
	pc = "!git push && gh pr create -w"
	puff = push --force-if-includes --force-with-lease
